{{define "layout"}}
<div class="ocli" data-theme="light">
  {{template "sidebar" .}}
  <div class="ocli__main">
    {{template "sectionIntro" .}}
    {{- if .Doc.Install}}{{template "sectionInstall" .}}{{end}}
    {{- if .Doc.Global}}
      {{- if or .Doc.Global.Config.JSON .Doc.Global.Config.TOML .Doc.Global.Config.YAML}}
      {{template "sectionConfig" .}}
      {{- end}}
      {{- if .Doc.Global.ExitCodes}}
      {{template "sectionExitCodes" .}}
      {{- end}}
    {{- end}}
    {{- if and .Doc.Commands .Doc.Commands.Commands}}
    {{- range .Doc.Commands.Commands}}{{template "commandSection" .}}{{end}}
    {{- end}}
    {{- if .Opts.IncludeFooter}}
    <footer class="ocli-footer">
      generated by <a href="https://github.com/bcdxn/opencli">OpenCLI</a>
    </footer>
    {{- end}}
  </div>
</div>
{{end}}
