{
  "opencliVersion": "1.0.0-alpha.10",
  "info": {
    "title": "PetStore CLI",
    "summary": "An example CLI Document describing operations a petstore CLI may provide.",
    "description": "`petstore` is an example command line interface designed to make working with the\n[PetStore API](https://petstore3.swagger.io) easier. It provides a number of\ncapabilities, including:\n\n- validating request parameters\n- executing API requests\n- parsing the API response\n- handling API errors\n\nThe commands are documented below. You can also find out more about each\ncommand using the contextual `--help` flag. e.g.:\n\n```sh\npetstore --help\n```\n",
    "license": {
      "name": "MIT",
      "spdxId": "MIT",
      "url": "https://spdx.org/licenses/MIT.html"
    },
    "contact": {
      "name": "OpenCLI Team",
      "url": "https://github.com/bcdxn/opencli"
    },
    "binary": "petstore",
    "version": "1.0.0"
  },
  "install": [
    {
      "name": "Binary Download",
      "url": "https://github.com/bcdxn/petstorecli/releases",
      "description": "A fake releases endpoint - no real release of this CLI exists"
    },
    {
      "name": "Go Install",
      "command": "go install github.com/bcdxn/petstore/cmd/cli@latest",
      "description": "A fake go install - no real release of this CLI exists"
    }
  ],
  "global": {
    "exitCodes": [
      { "code": 0, "status": "OK", "summary": "The command was successful" },
      {
        "code": 1,
        "status": "INTERNAL_CLI_ERROR",
        "summary": "The command failed"
      },
      {
        "code": 2,
        "status": "BAD_USER_INPUT_ERROR",
        "summary": "Missing or invalid input"
      }
    ],
    "config": {
      "json": "~/.petstore/config.json",
      "toml": "~/.petstore/config.toml",
      "yaml": "~/.petstore/config.yaml"
    }
  },
  "commands": {
    "petstore {command} <arguments> [flags]": {
      "hidden": false,
      "group": true
    },
    "petstore list": {
      "summary": "List all endpoints available",
      "aliases": ["ls"],
      "hidden": false,
      "group": false
    },
    "petstore pet {command} <arguments> [flags]": {
      "summary": "A collection of commands for managing pets",
      "hidden": false,
      "group": true
    },
    "petstore pet add <path-to-req-body> [flags]": {
      "summary": "Add a new pet to the store",
      "description": "Create a new pet in the store using a JSON payload or explicit flags.\n",
      "args": [
        {
          "name": "path-to-req-body",
          "type": "string",
          "variadic": false,
          "summary": "The path to a JSON file containing the new pet payload",
          "description": "A JSON formatted file with the exact POST body to send as part of the request to add a\nnew pet to the store using the PetStore API. The exact schema can be found\n[here](https://petstore3.swagger.io/api/v3/openapi.json#/components/schemas/PetPet). You\ncan use this option instead of passing individual flags.\n",
          "required": false,
          "default": null,
          "hidden": false
        }
      ],
      "flags": [
        {
          "name": "name",
          "aliases": ["n"],
          "type": "string",
          "variadic": false,
          "summary": "The name of the pet",
          "required": false,
          "hidden": false
        },
        {
          "name": "photoUrls",
          "aliases": ["p"],
          "type": "string",
          "variadic": true,
          "summary": "A list of photo URLs to display for the pet",
          "description": "Provide this flag multiple times to set multiple photo URLs.\n",
          "required": false,
          "hidden": false
        },
        {
          "name": "status",
          "type": "string",
          "variadic": false,
          "summary": "The pet status in the store",
          "required": false,
          "hidden": false,
          "choices": [
            { "value": "available" },
            { "value": "pending" },
            { "value": "sold" }
          ]
        },
        {
          "name": "tag",
          "type": "string",
          "variadic": true,
          "summary": "Tag to assign to the pet for grouping/sorting",
          "description": "Provide this flag multiple times to add multiple tags.\n",
          "required": false,
          "hidden": false
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore pet delete [flags]": {
      "summary": "Delete a pet",
      "flags": [
        {
          "name": "id",
          "type": "integer",
          "variadic": false,
          "summary": "The ID of the pet to delete",
          "required": true,
          "hidden": false
        },
        {
          "name": "api-key",
          "type": "string",
          "variadic": false,
          "summary": "API key header used to authorize the delete request",
          "required": false,
          "hidden": false
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore pet find-by-status [flags]": {
      "summary": "Find pets by status",
      "flags": [
        {
          "name": "status",
          "type": "string",
          "variadic": false,
          "summary": "The status to filter pets by",
          "required": true,
          "hidden": false,
          "choices": [
            { "value": "available" },
            { "value": "pending" },
            { "value": "sold" }
          ]
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore pet find-by-tags [flags]": {
      "summary": "Find pets by tags",
      "flags": [
        {
          "name": "tags",
          "type": "string",
          "variadic": true,
          "summary": "The tags to filter pets by",
          "description": "Provide this flag multiple times to filter by multiple tags.\n",
          "required": false,
          "hidden": false
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore pet get [flags]": {
