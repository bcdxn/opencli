        {
          "name": "id",
          "type": "integer",
          "variadic": false,
          "summary": "The ID of the pet to retrieve",
          "required": true,
          "hidden": false
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore pet update <path-to-req-body> [flags]": {
