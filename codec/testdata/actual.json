        {
          "name": "path-to-req-body",
          "type": "string",
          "variadic": false,
          "summary": "The path to a JSON file containing the updated pet payload",
          "required": false,
          "default": null,
          "hidden": false
        }
      ],
      "flags": [
        {
          "name": "name",
          "aliases": ["n"],
          "type": "string",
          "variadic": false,
          "summary": "The updated name of the pet",
          "required": false,
          "hidden": false
        },
        {
          "name": "status",
          "type": "string",
          "variadic": false,
          "summary": "The updated pet status",
          "required": false,
          "hidden": false,
          "choices": [
            { "value": "available" },
            { "value": "pending" },
            { "value": "sold" }
          ]
        },
        {
          "name": "photoUrls",
          "aliases": ["p"],
          "type": "string",
          "variadic": true,
          "summary": "A list of photo URLs to display for the pet",
          "description": "Provide this flag multiple times to set multiple photo URLs.\n",
          "required": false,
          "hidden": false
        },
        {
          "name": "tags",
          "type": "string",
          "variadic": true,
          "summary": "Tags to assign to the pet",
          "description": "Provide this flag multiple times to add multiple tags.\n",
          "required": false,
          "hidden": false
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore pet update-form [flags]": {
      "summary": "Update a pet using form data",
      "flags": [
        {
          "name": "id",
          "type": "integer",
          "variadic": false,
          "summary": "The ID of the pet to update",
          "required": true,
          "hidden": false
        },
        {
          "name": "name",
          "type": "string",
          "variadic": false,
          "summary": "The new name for the pet",
          "required": false,
          "hidden": false
        },
        {
          "name": "status",
          "type": "string",
          "variadic": false,
          "summary": "The new status for the pet",
          "required": false,
          "hidden": false,
          "choices": [
            { "value": "available" },
            { "value": "pending" },
            { "value": "sold" }
          ]
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore pet upload-image <path-to-file> [flags]": {
      "summary": "Upload an image for a pet",
      "description": "Upload a binary image file for the specified pet.\n",
      "args": [
        {
          "name": "path-to-file",
          "type": "string",
          "variadic": false,
          "summary": "The path to the file to upload",
          "required": true,
          "default": null,
          "hidden": false
        }
      ],
      "flags": [
        {
          "name": "id",
          "type": "integer",
          "variadic": false,
          "summary": "The ID of the pet",
          "required": true,
          "hidden": false
        },
        {
          "name": "additionalMetadata",
          "type": "string",
          "variadic": false,
          "summary": "Additional metadata to store with the uploaded image",
          "required": false,
          "hidden": false
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore store {command} <arguments> [flags]": {
      "summary": "A collection of commands for store operations",
      "hidden": false,
      "group": true
    },
    "petstore store inventory": {
      "summary": "Returns pet inventories by status",
      "hidden": false,
      "group": false
    },
    "petstore store order {command} <arguments> [flags]": {
      "summary": "A collection of commands for purchase orders",
      "hidden": false,
      "group": true
    },
    "petstore store order delete <id>": {
      "summary": "Delete purchase order by ID",
      "args": [
        {
          "name": "id",
