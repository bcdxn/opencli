    "petstore store order place <path-to-order-body> [flags]": {
      "summary": "Place an order for a pet",
      "description": "Create a purchase order using a JSON payload or explicit flags.\n",
      "args": [
        {
          "name": "path-to-order-body",
          "type": "string",
          "variadic": false,
          "summary": "The path to a JSON file containing the order payload",
          "required": false,
          "default": null,
          "hidden": false
        }
      ],
      "flags": [
        {
          "name": "pet-id",
          "type": "integer",
          "variadic": false,
          "summary": "The ID of the pet to order",
          "required": false,
          "hidden": false
        },
        {
          "name": "quantity",
          "type": "integer",
          "variadic": false,
          "summary": "How many pets to order",
          "required": false,
          "hidden": false
        },
        {
          "name": "status",
          "type": "string",
          "variadic": false,
          "summary": "The order status",
          "required": false,
          "hidden": false,
          "choices": [
            { "value": "placed" },
            { "value": "approved" },
            { "value": "delivered" }
          ]
        },
        {
          "name": "complete",
          "type": "boolean",
          "variadic": false,
          "summary": "Whether the order has been completed",
          "required": false,
          "hidden": false
        }
      ],
      "hidden": false,
      "group": false
    },
    "petstore user {command} <arguments> [flags]": {
      "hidden": false,
      "group": true
    },
